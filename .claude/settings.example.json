{
  "_comment": "Team baseline for .claude/settings.json. Copy to .claude/settings.json (gitignored) and add personal hooks as needed. Documented in docs/code-review-graph-sop.md.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph update --skip-flows",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph build && python3 scripts/build_code_graph_viz.py >/dev/null 2>&1 &",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph status",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -m tools.pipette.subagent_stop",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
