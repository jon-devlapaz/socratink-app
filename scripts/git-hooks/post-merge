#!/usr/bin/env bash
# post-merge hook
#
# Fires after `git merge` and `git pull` (which is fetch + merge).
# Kicks off an incremental code-review-graph update in the background
# so the graph reflects merged-in changes without blocking the merge.
#
# Best-effort: if code-review-graph isn't installed, this hook is a
# silent no-op. Output is suppressed to avoid spamming the terminal
# after every pull.

if command -v code-review-graph >/dev/null 2>&1; then
  ( code-review-graph update --skip-flows >/dev/null 2>&1 & ) >/dev/null 2>&1
fi

exit 0
