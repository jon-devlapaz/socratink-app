#!/usr/bin/env bash
# post-commit hook
#
# Fires after every successful `git commit`. Kicks off an incremental
# graph update in the background so the graph reflects the just-
# committed changes. Non-blocking and non-failing.
#
# Note: when an agent runs `git commit` via Bash, the Claude
# `PostToolUse: Edit|Write|Bash` hook also fires `code-review-graph
# update`. The redundant call is cheap (both background, both
# incremental, both no-op when nothing changed under WAL).
#
# Best-effort: silent no-op if code-review-graph isn't installed.

if command -v code-review-graph >/dev/null 2>&1; then
  ( code-review-graph update --skip-flows >/dev/null 2>&1 & ) >/dev/null 2>&1
fi

exit 0
