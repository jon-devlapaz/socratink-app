```css
/* ============================================================
   Creation dialog — center-stage composition surface.
   Not a cramped modal; a reading-room canvas.
   ============================================================ */
.creation-dialog {
  position: fixed;
  inset: 0;
  z-index: 9000;
  display: none;
}
.creation-dialog[data-open="true"] {
  display: flex;
  align-items: center;
  justify-content: center;
}
.creation-dialog-scrim {
  position: absolute;
  inset: 0;
  background: var(--overlay-backdrop);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  opacity: 0;
  transition: opacity var(--duration-cozy) var(--ease-standard);
}
.creation-dialog[data-open="true"] .creation-dialog-scrim {
  opacity: 1;
}
.creation-dialog-shell {
  position: relative;
  width: min(560px, calc(100vw - 48px));
  max-height: calc(100vh - 64px);
  overflow-y: auto;
  padding: var(--space-6) var(--space-8);
  background: linear-gradient(180deg, var(--gradient-card-start), var(--gradient-card-end));
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-hero), inset 0 1px 0 rgba(var(--white-rgb), 0.78);
  backdrop-filter: blur(18px);
  transform: translateY(12px);
  opacity: 0;
  transition:
    transform var(--duration-cozy) var(--ease-standard),
    opacity   var(--duration-cozy) var(--ease-standard);
}
.creation-dialog[data-open="true"] .creation-dialog-shell {
  transform: translateY(0);
  opacity: 1;
}
.creation-dialog-kicker {
  font-family: var(--font-display);
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: var(--tracking-kicker);
