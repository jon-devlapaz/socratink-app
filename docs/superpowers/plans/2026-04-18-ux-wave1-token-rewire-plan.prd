```

- [ ] **Step 2: Refactor `startAddConcept` in `public/js/app.js` to mount dialog**

Current implementation lives at L822-1206. Refactor the render path:

Replace the sidebar-render at L823-825:
```javascript
addTriggerArea.style.overflowY = 'auto';
addTriggerArea.innerHTML = '<div class="creation-form"></div>';
const form = addTriggerArea.querySelector('.creation-form');
```
with a dialog mount:
```javascript
window.__creationDialogTrigger = document.activeElement;   // for focus-return
const dialog = mountCreationDialog();
const formHost = dialog.shellContent;
const isGuest = await detectGuestMode();

// NOTE: buildContentInputUI writes container.innerHTML (app.js:454). Banner
// must go into dialog.bannerSlot (separate DOM node above the content area),
// never prepended into formHost — the first buildContentInputUI call would
// wipe it.
```

Then let `buildContentInputUI(formHost, …)` render as before. After it returns, render the banner into `dialog.bannerSlot`:

```javascript
dialog.bannerSlot.innerHTML = '';
if (isGuest) {
  dialog.bannerSlot.appendChild(buildGuestBanner());
  // Disable submit (honest signal; not auth enforcement — guard is contract-level)
  formHost.querySelectorAll('input, textarea, button.submit-btn, [type="submit"]').forEach((el) => {
    el.disabled = true;
  });
}

// Focus first enabled input (or banner link if everything is disabled)
const firstFocusable = dialog.shell.querySelector('input:not([disabled]), textarea:not([disabled]), a, button:not([disabled])');
firstFocusable?.focus();
```

Add helpers near `startAddConcept`:

```javascript
// Track which sibling elements we inerted so we can restore exactly what we changed.
// The app has no single #app-root wrapper — #card, #drawer, #backdrop, #bottom-nav are all body children.
let __dialogInertedNodes = [];

function mountCreationDialog() {
  let node = document.getElementById('creation-dialog');
  const firstMount = !node;
  if (firstMount) {
    node = document.createElement('div');
    node.id = 'creation-dialog';
    node.className = 'creation-dialog';
    node.setAttribute('role', 'dialog');
    node.setAttribute('aria-modal', 'true');
    node.setAttribute('aria-labelledby', 'creation-dialog-title');
    node.innerHTML = `
      <div class="creation-dialog-scrim"></div>
      <div class="creation-dialog-shell">
        <div class="creation-dialog-header">
          <span class="creation-dialog-kicker">New concept</span>
          <button class="creation-dialog-close" type="button" aria-label="Close">×</button>
        </div>
        <h3 id="creation-dialog-title" class="creation-dialog-title">Bring your material.</h3>
        <div class="creation-dialog-banner-slot"></div>
        <div class="creation-dialog-content"></div>
        <p class="creation-dialog-meta">Your words shape the path; they do not grade you.</p>
      </div>
    `;
    document.body.appendChild(node);
    // Listeners bound once on first mount; they read current DOM state each time.
    node.querySelector('.creation-dialog-close').addEventListener('click', () => closeCreationDialog());
    node.querySelector('.creation-dialog-scrim').addEventListener('click', () => closeCreationDialog());
    const shell = node.querySelector('.creation-dialog-shell');
    shell.addEventListener('keydown', trapFocusHandler);
  }
  node.dataset.open = 'true';

  // Inert every top-level body child except the dialog itself.
  // The app is currently #drawer + #backdrop + #card + #bottom-nav, plus brand etc.
  __dialogInertedNodes = Array.from(document.body.children).filter(
    (el) => el !== node && !el.hasAttribute('inert')
  );
  __dialogInertedNodes.forEach((el) => el.setAttribute('inert', ''));
  document.addEventListener('keydown', creationDialogKeyHandler);
  return {
    node,
    shell: node.querySelector('.creation-dialog-shell'),
    shellContent: node.querySelector('.creation-dialog-content'),
    bannerSlot: node.querySelector('.creation-dialog-banner-slot'),
  };
}

function closeCreationDialog() {
  const node = document.getElementById('creation-dialog');
  if (!node) return;
  node.dataset.open = 'false';
  __dialogInertedNodes.forEach((el) => el.removeAttribute('inert'));
  __dialogInertedNodes = [];
  document.removeEventListener('keydown', creationDialogKeyHandler);
  setTimeout(() => {
    if (node.dataset.open === 'false') {
      const banner = node.querySelector('.creation-banner');
      if (banner) banner.remove();
      const content = node.querySelector('.creation-dialog-content');
      if (content) content.innerHTML = '';
    }
  }, 350);
  (window.__creationDialogTrigger || document.body).focus?.();
}

function trapFocusHandler(e) {
  if (e.key !== 'Tab') return;
  const container = e.currentTarget;
  const focusables = container.querySelectorAll(
    'button:not([disabled]), [href], input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'
  );
  if (!focusables.length) return;
  const first = focusables[0];
  const last = focusables[focusables.length - 1];
  if (e.shiftKey && document.activeElement === first) {
    e.preventDefault();
    last.focus();
  } else if (!e.shiftKey && document.activeElement === last) {
    e.preventDefault();
    first.focus();
  }
}

function creationDialogKeyHandler(e) {
  if (e.key === 'Escape') closeCreationDialog();
}

async function detectGuestMode() {
  try {
    const session = await fetchAuthSession();
    return !!(session && session.guest_mode === true);
  } catch {
    return false;
  }
}

function buildGuestBanner() {
  const banner = document.createElement('div');
  banner.className = 'creation-banner creation-banner--guest';
  banner.innerHTML = `
    <div>
      <strong>Guest mode uses sample maps.</strong><br>
      Sign in to extract your own content into a real knowledge map.
      <a href="${escHtml(buildLoginHref('/'))}" style="color: var(--accent-primary); font-weight: 600;">Sign in →</a>
    </div>
  `;
  return banner;
}

function buildErrorBanner(sanitizedMessage) {
  const banner = document.createElement('div');
  banner.className = 'creation-banner creation-banner--error';
  banner.innerHTML = `
    <div>
      <strong>Extraction didn't complete.</strong><br>
      ${escHtml(sanitizedMessage)}
    </div>
  `;
  return banner;
}

function sanitizeExtractError(err) {
  // User-facing, never echoes raw err.message — auth headers / stack fragments leak otherwise.
  if (!err) return 'Something went wrong. Try again when ready.';
  const msg = String(err.message || '');
  if (/\b401|unauthor/i.test(msg)) return 'Sign in required to run extraction.';
  if (/\b403|forbidden/i.test(msg)) return 'That request was not allowed.';
  if (/\b429|rate limit/i.test(msg)) return 'Extraction service is throttled. Give it a minute and retry.';
  if (/\b5\d{2}|server error/i.test(msg)) return 'The extraction service hiccuped. Try again when ready.';
  return 'The network or service was unreachable. Try again when ready.';
}
```

- [ ] **Step 3: Invariant guard on extraction success path**

In `startAddConcept`'s `onSubmit` handler (current L830-1199), the critical section is where `jsonPayload` returns and the concept is pushed (current L1140-1177). Wrap the push path in a contract validator:

Replace:
```javascript
const jsonPayload = await window.AIService.generateKnowledgeMap(sourceText);
const durationMs = Math.round(performance.now() - extractStartedPerf);

removeOverlay(true);
const concept = { id, name, state: 'growing', ... , graphData: JSON.stringify(jsonPayload) };
// ...
contentStore.set(id, sourceText);
concepts.push(concept);
saveConcepts(concepts);
```

with:

```javascript
const jsonPayload = await window.AIService.generateKnowledgeMap(sourceText);
const durationMs = Math.round(performance.now() - extractStartedPerf);

// INVARIANT: failed extraction never mutates contentStore / concepts.
// Validate payload shape before any state mutation.
if (!isValidKnowledgeMap(jsonPayload)) {
  removeOverlay();
  throw new Error('Extraction returned an invalid map.');
}

removeOverlay(true);
const concept = { id, name, state: 'growing', ..., graphData: JSON.stringify(jsonPayload) };
// ...
contentStore.set(id, sourceText);
concepts.push(concept);
saveConcepts(concepts);
```

Add validator helper near the top of the file (or beside `STARTER_MAPS`):

```javascript
function isValidKnowledgeMap(map) {
  if (!map || typeof map !== 'object') return false;
  if (!Array.isArray(map.backbone) || map.backbone.length === 0) return false;
  if (!Array.isArray(map.clusters)) return false;
  return true;
}
```

- [ ] **Step 4: Sanitized error banner in dialog on failure**

Replace the existing `catch (err) { ... alert(...); }` block (current L1181-1199) with:

```javascript
} catch (err) {
  removeOverlay();
  const sanitized = sanitizeExtractError(err);
  recordExtractRun({
    timestamp: extractStartedAt,
    stage: 'extract',
    status: 'error',
    model: 'gemini-2.5-flash',
    prompt_version: 'extract-system-v1',
    concept_id: id,
    source_title: name,
    content_type: type,
    input_chars: typeof text === 'string' ? text.length : 0,
    duration_ms: Math.round(performance.now() - extractStartedPerf),
    error_type: 'request_failed',
    // reason is USER-VISIBLE via browser-analytics.js:326 — MUST be sanitized.
    reason: sanitized,
    // reason_raw is for debugging; never rendered. Add only if schema allows.
    reason_raw: err?.message || null,
    run_mode: 'default',
  });
  console.warn('[extract] raw error (console only):', err);
  const bannerSlot = document.querySelector('.creation-dialog-banner-slot');
  if (bannerSlot) {
    const existing = bannerSlot.querySelector('.creation-banner--error');
    if (existing) existing.remove();
    bannerSlot.appendChild(buildErrorBanner(sanitized));
  }
  const formHost = document.querySelector('.creation-dialog-content');
  formHost?.querySelectorAll('button, input, textarea').forEach((el) => { el.disabled = false; });
}
```

**Caution:** if `recordExtractRun`'s stored schema does NOT accept arbitrary keys (e.g., strict validator), omit `reason_raw` entirely; console-only suffices. Grep `recordExtractRun` definition to confirm shape before adding the new field.

Keep the existing non-error path's `closeCreationDialog()` call at the success branch so the dialog only closes when a concept is saved.

