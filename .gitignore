# Claude Code local settings (machine-specific, not for version control).
# Re-include the directory then ignore its contents so we can whitelist the
# settings.example.json team-baseline template.
!.claude/
.claude/*
!.claude/settings.example.json
!.claude/commands/
.claude/commands/*
!.claude/commands/pipette.md
!.claude/commands/pipette-weekly.md
!.claude/commands/pipette-lite.md
!.claude/skills/
.claude/skills/*
!.claude/skills/git-order/
!.claude/skills/git-order/SKILL.md
.kiro/
.playwright-cli/
.firecrawl/

# macOS
.DS_Store

# Python
.env
__pycache__/
*.py[cod]
.venv*/
.venv/
.pytest_cache/

# Node (anywhere in the tree — keep node_modules out of git/Vercel uploads)
node_modules/



# Local diagnostics
logs/
tmp/
output/

# Local agent runtime context
.codex/
.vscode/
learnops/

# Track durable repo doctrine and docs.
!AGENTS.md
!docs/
!docs/**
docs/**/.DS_Store

# Local-only checks and exports unless promoted into tracked scripts/tests.
scripts/run-checks.sh

# Local deployment and environment state
.vercel
.env*.local

# db/ holds tracked schema only — keep local seed/env spillover out.
db/.env*
db/*.local.*

# Generated by local `vercel build` when using requirements.txt as source.
pyproject.toml
uv.lock

.mcp.json
.gm-stop-verified
.codeinsight

# Superpowers worktrees
.worktrees/
.superpowers/

# QA + tool artifacts (do not track)
.playwright-mcp/
*.excalidraw
!docs/diagrams/*.excalidraw
c4-mobile-*.png
map-header-*.png
b&a/

# Local knowledge-base + scratch (not for version control)
.socratink-brain/.obsidian/
docs/research/
docs/pipeline/
# Added by code-review-graph
.code-review-graph/
docs/code-graph.html
