# Copy to .env and fill in. Vite exposes only VITE_-prefixed vars to the client.
# Token needs: repo (full control of private repos) — or public_repo if the repo is public.
VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx
VITE_GITHUB_OWNER=jon-devlapaz
VITE_GITHUB_REPO=socratink-app
VITE_MAIN_BRANCH=main
# Optional. If set, enables the chat panel powered by Gemini 2.5 Flash.
VITE_GEMINI_API_KEY=
