#!/usr/bin/env bash
# riverflow — one-shot launcher.
# Auto-detects the GitHub repo from the cwd's `origin` remote, manages a
# stored token at ~/.config/riverflow/token, installs deps on first run,
# and opens the visualizer in your browser.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INVOKED_FROM="$PWD"
TOKEN_FILE="$HOME/.config/riverflow/token"
GEMINI_TOKEN_FILE="$HOME/.config/riverflow/gemini-token"
PORT="${RIVERFLOW_PORT:-5180}"

die() { echo "riverflow: $*" >&2; exit 1; }

# 1. Detect repo from caller's cwd
cd "$INVOKED_FROM"
git rev-parse --git-dir >/dev/null 2>&1 \
  || die "must run inside a git repo (cwd: $INVOKED_FROM)"

REMOTE_URL="$(git remote get-url origin 2>/dev/null || true)"
[[ -n "$REMOTE_URL" ]] || die "no 'origin' remote in this repo"

if [[ "$REMOTE_URL" =~ github\.com[:/]+([^/]+)/([^/]+)$ ]]; then
  OWNER="${BASH_REMATCH[1]}"
  REPO="${BASH_REMATCH[2]%.git}"
else
  die "cannot parse GitHub owner/repo from '$REMOTE_URL'"
fi

MAIN_BRANCH="$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null \
              | sed 's@^origin/@@' || true)"
[[ -n "$MAIN_BRANCH" ]] || MAIN_BRANCH="main"

# 2. Token: env → file → prompt-and-save
if [[ -n "${GITHUB_TOKEN:-}" ]]; then
  TOKEN="$GITHUB_TOKEN"
elif [[ -s "$TOKEN_FILE" ]]; then
  TOKEN="$(cat "$TOKEN_FILE")"
else
  mkdir -p "$(dirname "$TOKEN_FILE")"
  echo "riverflow: no token found." >&2
  echo "Create one at https://github.com/settings/tokens (classic, 'repo' scope)." >&2
  printf "Paste GitHub PAT (will be saved to %s, chmod 600): " "$TOKEN_FILE" >&2
  read -rs TOKEN
  echo >&2
  [[ -n "$TOKEN" ]] || die "empty token"
  printf '%s' "$TOKEN" > "$TOKEN_FILE"
  chmod 600 "$TOKEN_FILE"
fi

# 2b. Gemini API key (optional — enables the chat panel)
GEMINI_KEY=""
if [[ -n "${GEMINI_API_KEY:-}" ]]; then
  GEMINI_KEY="$GEMINI_API_KEY"
elif [[ -s "$GEMINI_TOKEN_FILE" ]]; then
  GEMINI_KEY="$(cat "$GEMINI_TOKEN_FILE")"
fi

# 3. Install deps once
cd "$SCRIPT_DIR"
if [[ ! -d node_modules ]]; then
  echo "riverflow: installing dependencies (one-time)…" >&2
  npm install --silent --no-fund --no-audit
fi

# 4. Write .env for Vite (regenerated every run; cwd-aware)
cat > .env <<EOF
VITE_GITHUB_TOKEN=$TOKEN
VITE_GITHUB_OWNER=$OWNER
VITE_GITHUB_REPO=$REPO
VITE_MAIN_BRANCH=$MAIN_BRANCH
VITE_GEMINI_API_KEY=$GEMINI_KEY
EOF

echo "riverflow: $OWNER/$REPO  ($MAIN_BRANCH)  →  http://localhost:$PORT" >&2
if [[ -z "$GEMINI_KEY" ]]; then
  echo "  (chat disabled — paste a key into $GEMINI_TOKEN_FILE to enable)" >&2
fi

# 5. Run dev server, open browser
exec npx --yes vite --host=127.0.0.1 --port="$PORT" --open
